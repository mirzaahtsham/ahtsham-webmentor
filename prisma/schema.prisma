generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model ContactMessage {
  id          String   @id @default(uuid())
  name        String?
  email       String?
  company     String?
  phone       String?
  projectType String?
  webDevType  String?
  budget      String?
  timeline    String?
  description String?
  createdAt   DateTime @default(now())
}
